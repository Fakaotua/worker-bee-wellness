# Demo Mode (for testing without real database connections)
NEXT_PUBLIC_DEMO_MODE=false

# -------------------------
# Supabase (Database + Auth)
# -------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# -------------------------
# App URL
# -------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------
# Square (Global Link + Webhooks)
# -------------------------
SQUARE_APPOINTMENTS_URL=https://squareup.com/appointments/your-link
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_secret

# -------------------------
# Email Provider (Resend)
# -------------------------
RESEND_API_KEY=your_resend_api_key

# -------------------------
# SMS Provider (Optional, Future)
# -------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15555555555
